<script>
document.addEventListener("DOMContentLoaded", function () {
    // Select the menu item
    let menuItem = document.getElementById("jet-mobile-menu-item-507");

    // Select the target Elementor widget
    let targetElement = document.querySelector(".elementor-element-35eaef8");

    if (menuItem && targetElement) {
        menuItem.addEventListener("click", function (event) {
            event.preventDefault(); // Prevent default link behavior (optional)

            // Toggle a class to show/hide the target element
            targetElement.classList.toggle("active");

            // Optionally, add smooth scrolling to the target
            targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
        });
    }
});
</script>
